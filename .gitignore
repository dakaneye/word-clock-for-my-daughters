.DS_Store
.superpowers/
build/
hardware-mcp-workspace/
*.hex
*.elf
.pio/
.vscode/
node_modules/

# KiCad auto-generated
hardware/.history/
hardware/~*.lck
hardware/*-backups/
hardware/fp-info-cache

# KiCad plot / fabrication outputs — regenerated each time
hardware/*.gbr
hardware/*.gbrjob
hardware/*.drl
hardware/word-clock-*.pdf
hardware/word-clock-*.csv
hardware/word-clock-*.xlsx
hardware/word-clock-gerbers-*.zip
hardware/ERC.rpt
hardware/DRC.rpt
report.txt

# KiCad validation + MCP-tooling outputs (regenerated each time).
# hardware/fab/ keeps the as-ordered package (zip + cpl + bom) tracked,
# but its unzipped loose gerbers are regenerable.
hardware/output/
hardware/regen/
hardware/fab/gerbers/
*.rpt

# KiCad working backups — history lives in git, not in dated copies.
hardware/*.bak*
hardware/*.broken*
hardware/*.pre-*

# Enclosure generator
enclosure/scripts/fonts/
enclosure/scripts/__pycache__/
**/.pytest_cache/
**/__pycache__/
firmware/.cache/
