CompileFlags:
  # clangd runs its own bundled clang, which doesn't understand xtensa-specific
  # flags emitted by PlatformIO's ESP32 toolchain. Strip them from compile_commands.json.
  Remove:
    - -mlongcalls
    - -fstrict-volatile-bitfields
    - -fno-tree-switch-conversion
    # Arduino-ESP32 framework appends -std=gnu++11 AFTER our -std=gnu++17.
    # platformio.ini build_unflags strips it at actual build time, but the
    # entry can linger in compile_commands.json — strip again here.
    - -std=gnu++11
  Add:
    - -std=gnu++17
    # PlatformIO only generates compile_commands.json for the emory env, so
    # native-env test files (firmware/test/test_*/*.cpp) fall back to clangd's
    # default compiler invocation. Add the library include paths that
    # platformio.ini wires into [env:native].build_flags so fallback mode
    # resolves the pure-logic headers used by test files.
    - -Ilib/core/include
    - -Ilib/wifi_provision/include
    - -Ilib/buttons/include
    - -Ilib/display/include
    - -Iconfigs
    # Unity is a PlatformIO libdep bundled per-env; native tests find it
    # through pio's scons environment, but clangd's fallback invocation
    # needs the path explicit.
    - -I.pio/libdeps/native/Unity/src

# Suppress diagnostics that only fire when clangd's fallback compiler
# invocation can't resolve stdlib headers (the real PIO build uses gcc
# with a known-good stdlib; clangd's fallback mixes libc++ and libstdc++
# incompletely). Real build errors surface via `pio test -e native` and
# `pio run -e emory`, not the LSP.
Diagnostics:
  Suppress:
    - pp_file_not_found        # <_ansi.h>, <sys/types.h> fallback gaps
    - typename_nested_not_found  # std::__tree issues
    - nested_name_spec_non_tag   # std::allocator_traits confusion
    - expected_unqualified_id    # cascading from header-resolution failure
