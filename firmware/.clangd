CompileFlags:
  # clangd runs its own bundled clang, which doesn't understand xtensa-specific
  # flags emitted by PlatformIO's ESP32 toolchain. Strip them from compile_commands.json.
  Remove:
    - -mlongcalls
    - -fstrict-volatile-bitfields
    - -fno-tree-switch-conversion
    # Arduino-ESP32 framework appends -std=gnu++11 AFTER our -std=gnu++17.
    # platformio.ini build_unflags strips it at actual build time, but the
    # entry can linger in compile_commands.json — strip again here.
    - -std=gnu++11
  Add:
    - -std=gnu++17
    # PlatformIO only generates compile_commands.json for the emory env, so
    # native-env test files (firmware/test/test_*/*.cpp) fall back to clangd's
    # default compiler invocation. Add the library include paths that
    # platformio.ini wires into [env:native].build_flags so fallback mode
    # resolves the pure-logic headers used by test files.
    - -Ilib/core/include
    - -Ilib/wifi_provision/include
    - -Ilib/buttons/include
    - -Ilib/display/include
    - -Iconfigs
